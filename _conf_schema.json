{
  "push_time": {
    "description": "每日定时推送时间",
    "type": "string",
    "default": "08:00",
    "hint": "24小时制，如 08:30"
  },
  "target_groups": {
    "description": "推送目标群组/用户 ID",
    "type": "list",
    "default": [],
    "hint": "平台/类型/目标ID，例telegram:FriendMessage:你的ID或群号"
  },
  "city": {
    "description": "所在城市 (用于天气预报)",
    "type": "string",
    "default": "北京",
    "hint": "输入城市中文，如：上海"
  },
  "exchange_api_key": {
    "description": "汇率 API Key",
    "type": "string",
    "default": "",
    "hint": "前往 exchangerate-api.com 免费获取"
  },
  "base_currency": {
    "description": "基础货币",
    "type": "string",
    "default": "CNY"
  },
  "target_currencies": {
    "description": "目标货币代码",
    "type": "string",
    "default": "USD,JPY,EUR,GBP,HKD,AUD",
    "hint": "用英文逗号隔开"
  },
  "deepseek_key": {
    "description": "DeepSeek API Key",
    "type": "string",
    "default": "",
    "hint": "用于查询 DeepSeek 余额"
  },
  "moonshot_key": {
    "description": "Moonshot(Kimi) API Key",
    "type": "string",
    "default": "",
    "hint": "用于查询 Kimi 余额"
  }
}